{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-05-25 00:00:00.000000",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Sales Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Invoice Template</title>\n\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap\" rel=\"stylesheet\">\n\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 11px; line-height: 1.3; background-color: #f5f5f5; padding: 10px;\n            font-feature-settings: 'cv11', 'ss01'; font-variation-settings: 'slnt' 0;\n            -webkit-print-color-adjust: exact !important; color-adjust: exact !important; print-color-adjust: exact !important;\n        }\n\n        .invoice-container { max-width: 210mm; margin: 0 auto; background: white; border: 1px solid #333 !important; color: #000; position: relative; }\n\n        .company-header { text-align: center; padding: 8px; width: 100%; border-bottom: 1px solid #333 !important; }\n        .company-gstin { font-weight: 700; font-size: 14px; margin-bottom: 3px; letter-spacing: 1px; }\n        .company-name { font-weight: 700; font-size: 16px; text-transform: uppercase; }\n\n        .top-section-wrapper { display: flex; position: relative; }\n        .left-content { flex: 1; border-right: 1px solid #333 !important; }\n\n        .qr-section { width: 160px; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 6px 8px; }\n        .qr-section-header { font-weight: 700; font-size: 10px; text-align: center; margin-bottom: 5px; color: #000; letter-spacing: 0.3px; text-transform: uppercase; }\n        .qr-code-container { width: 130px; height: 130px; border: 1px solid #333 !important; display: flex; align-items: center; justify-content: center; background-color: #fff; }\n        .qr-code-container img { width: 126px; height: 126px; object-fit: contain; }\n\n        .qr-details { width: 100%; padding: 5px; font-size: 9px; text-align: center; }\n        .qr-details p { margin: 2px 0; word-wrap: break-word; word-break: break-all; white-space: normal; }\n        .field-property { margin: 1px 0; }\n\n        .einvoice-section { width: 100%; border-bottom: 1px solid #333 !important; }\n        .transaction-section { width: 100%; }\n\n        .section-title { font-weight: 600; font-size: 11px; margin: 0; padding: 4px 8px; width: 100%; }\n\n        .einvoice-table { width: 100%; border-collapse: collapse; font-size: 10px; border-top: 1px solid #333 !important; }\n        .einvoice-table td { border-top: 1px solid #333 !important; border-right: 1px solid #333 !important; padding: 3px 6px; vertical-align: top; font-size: 11px; }\n        .einvoice-table td:first-child { width: 80px; font-weight: 600; }\n\n        .transaction-table { width: 100%; border-collapse: collapse; font-size: 10px; }\n        .transaction-table td { border: 1px solid #333 !important; padding: 3px 6px; vertical-align: top; font-size: 11px; }\n        .transaction-table td:nth-child(1), .transaction-table td:nth-child(3) { width: 21%; font-weight: 600; }\n        .transaction-table td:nth-child(2), .transaction-table td:nth-child(4) { width: 30%; }\n\n        .full-width-content { width: 100%; }\n\n        .party-table { width: 100%; border-collapse: collapse; font-size: 10px; border-top: 1px solid #333 !important; }\n        .party-table td { border: 1px solid #333 !important; padding: 6px; vertical-align: top; width: 50%; }\n\n        .items-table { width: 100%; border-collapse: collapse; font-size: 9px; }\n        .items-table th, .items-table td { border: 1px solid #333 !important; padding: 2px 3px; text-align: center; vertical-align: middle; }\n        .items-table th { font-weight: 600; background-color: #f8f9fa !important; }\n        .items-table .desc-col { text-align: left; font-size: 8px; }\n        .items-table .num-col { text-align: right; }\n\n        .main-header { background-color: #e9ecef !important; font-weight: 700; }\n        .sub-header { background-color: #f1f3f4 !important; font-size: 8px; }\n        .total-row { font-weight: 600; }\n\n        .eway-table { width: 100%; border-collapse: collapse; font-size: 10px; }\n        .eway-table td { border: 1px solid #333 !important; padding: 3px 6px; vertical-align: top; }\n\n        .bottom-table { width: 100%; border-collapse: collapse; font-size: 10px; border-top: 1px solid #333 !important; }\n        .bottom-table td { border-left: 1px solid #333 !important; padding: 8px; vertical-align: top; }\n        .bottom-table td:first-child { border-left: none !important; }\n\n        .qr-side-cell { text-align: center; vertical-align: middle !important; width: 22%; }\n        .qr-side-cell img { width: 110px; height: 110px; object-fit: contain; border: 1px solid #333 !important; padding: 2px; background: #fff; }\n        .qr-side-cell .qr-caption { font-weight: 700; font-size: 10px; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px; }\n        .qr-side-cell .qr-subcaption { font-size: 9px; color: #333; margin-top: 2px; }\n\n        .letter-head-container, .letter-head-footer { margin: 0; padding: 0; height: auto; }\n\n        .bold { font-weight: 600; }\n        .text-right { text-align: right; }\n        .text-center { text-align: center; }\n\n        @media print {\n            body { background: white !important; padding: 0 !important; margin: 0 !important;\n                -webkit-print-color-adjust: exact !important; color-adjust: exact !important; print-color-adjust: exact !important; }\n            .invoice-container { border: 1px solid #333 !important; box-shadow: none !important; margin: 0 !important; max-width: none !important; width: 100% !important; }\n            table, th, td { border-color: #333 !important; border-style: solid !important; border-width: 0px !important; }\n            .company-header { border-bottom: 1px solid #333 !important; }\n            .left-content { border-right: 1px solid #333 !important; }\n            .einvoice-section { border-bottom: 1px solid #333 !important; }\n            .qr-code-container { border: 1px solid #333 !important; }\n            .qr-side-cell img { border: 1px solid #333 !important; }\n            .items-table th { background-color: #f8f9fa !important; -webkit-print-color-adjust: exact !important; }\n            .main-header { background-color: #e9ecef !important; -webkit-print-color-adjust: exact !important; }\n            .sub-header { background-color: #f1f3f4 !important; -webkit-print-color-adjust: exact !important; }\n        }\n\n        @page { margin: 0.5in; size: A4; }\n    </style>\n</head>\n<body>\n    <div class=\"invoice-container\">\n        <div id=\"header-html\" class=\"letter-head-container\">\n            {% if letter_head %}\n                <div class=\"letter-head\">{{ letter_head }}</div>\n            {% endif %}\n        </div>\n\n        <div class=\"company-header\">\n            <div class=\"company-gstin\">{{ frappe.db.get_value(\"Address\", doc.company_address, \"gstin\") or \"32AAGFC3363E1ZX\" }}</div>\n            <div class=\"company-name\">{{ doc.company or \"CHUNDAKADAN AGENCIES\" }}</div>\n        </div>\n\n        <div class=\"top-section-wrapper\">\n            <div class=\"left-content\">\n                <div class=\"einvoice-section\">\n                    <div class=\"section-title\">1.e-Invoice Details</div>\n                    <table class=\"einvoice-table\">\n                        <tr>\n                            <td>IRN</td>\n                            <td><b>{{ doc.irn }}</b></td>\n                        </tr>\n                        <tr>\n                            <td>Ack No.</td>\n                            <td>\n                                {% if doc.irn %}\n                                    {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                                    {% if e_invoice_log %}\n                                        {% set invoice_data = json.loads(e_invoice_log.invoice_data) %}\n                                        {% set date_format = frappe.db.get_single_value(\"System Settings\",'date_format').replace(\"mm\",\"MM\") %}\n                                        <b>{{ invoice_data.get(\"AckNo\") if invoice_data.get(\"AckNo\") else '' }}</b> &nbsp;&nbsp;&nbsp;&nbsp;\n                                        <span>Ack Date : <b>{{ frappe.utils.format_datetime(invoice_data.get(\"AckDt\"),date_format) if invoice_data.get(\"AckDt\") else doc.posting_date }}</b></span>\n                                    {% else %}\n                                        <b></b> &nbsp;&nbsp;&nbsp;&nbsp;\n                                        <span>Ack Date : <b>{{ doc.posting_date }} {{ doc.posting_time }}</b></span>\n                                    {% endif %}\n                                {% endif %}\n                            </td>\n                        </tr>\n                    </table>\n                </div>\n\n                <div class=\"transaction-section\">\n                    <div class=\"section-title\">2.Transaction Details</div>\n                    <table class=\"transaction-table\">\n                        <tr>\n                            <td>Category</td>\n                            <td><b>B2B</b></td>\n                            <td>Document No</td>\n                            <td><b>{{ doc.name }}</b></td>\n                        </tr>\n                        <tr>\n                            <td>Document Type</td>\n                            <td><b>{{ doc.select_print_heading if doc.select_print_heading else 'Tax Invoice' }}</b></td>\n                            <td>Document Date</td>\n                            <td><b>{{ doc.posting_date }}</b></td>\n                        </tr>\n                    </table>\n                </div>\n            </div>\n\n            <div class=\"qr-section\">\n                <div class=\"qr-section-header\">India Compliance<br>GST E-Invoice</div>\n                <div class=\"qr-code-container\">\n                    {% if doc.irn %}\n                        {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                        {% if e_invoice_log and e_invoice_log.signed_qr_code %}\n                            {{ web_block('e-Invoice QR', values={'e_invoice_qr_text': e_invoice_log.signed_qr_code }) }}\n                        {% endif %}\n                    {% endif %}\n                </div>\n\n                {% if doc.irn %}\n                    {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                    {% if e_invoice_log %}\n                        {% set invoice_data = json.loads(e_invoice_log.invoice_data) %}\n                        {% set date_format = frappe.db.get_single_value(\"System Settings\",'date_format').replace(\"mm\",\"MM\") %}\n                        <div class=\"qr-details\">\n                            <p class=\"field-property\"><b>IRN :</b><br><span style=\"word-wrap: break-word;word-break: break-all;white-space: normal;\">{{ doc.irn }}</span></p>\n                            <p class=\"field-property\"><b>Ack No.</b><br><span>{{ invoice_data.get(\"AckNo\") if invoice_data.get(\"AckNo\") else '' }}</span></p>\n                            <p class=\"field-property\"><b>Ack Dt.</b><br><span>{{ frappe.utils.format_datetime(invoice_data.get(\"AckDt\"),date_format) if invoice_data.get(\"AckDt\") else '' }}</span></p>\n                        </div>\n                    {% endif %}\n                {% endif %}\n            </div>\n        </div>\n\n        <div class=\"full-width-content\">\n            <div class=\"section-title\">Details of Receiver (Billed to)</div>\n            <table class=\"party-table\">\n                <tr>\n                    <td style=\"font-size: 11px;\">\n                        <div class=\"bold\">Seller</div><br>\n                        {% set company_addr = frappe.get_doc(\"Address\", doc.company_address) if doc.company_address else None %}\n                        {% if company_addr %}\n                        <div><span class=\"bold\">GSTIN :</span> <strong>{{ company_addr.gstin }}</strong></div>\n                        <div class=\"bold\">{{ company_addr.address_title }}</div>\n                        <div>{{ company_addr.address_line1 }}{% if company_addr.address_line2 %}, {{ company_addr.address_line2 }}{% endif %}<br>{{ company_addr.city }}</div>\n                        <div><span>PIN :</span> {{ company_addr.pincode }}</div>\n                        <div><span>E-Mail :</span> {{ company_addr.email_id }}</div>\n                        <div><span>State :</span> {{ company_addr.gst_state }}</div>\n                        <div><span>State Code :</span> {{ company_addr.gst_state_number }}</div>\n                        <div><span>Mobile :</span> {{ company_addr.phone }}</div>\n                        <div><span>Phone :</span> {{ company_addr.phone }}</div>\n                        {% endif %}\n                    </td>\n                    <td style=\"font-size: 11px;\">\n                        <div class=\"bold\">Purchaser</div><br>\n                        {%- set customer_doc = frappe.get_doc(\"Customer\", doc.customer) if doc.customer else None -%}\n                        {%- set addr_doc = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None -%}\n                        <div>GST No : <strong>{{ (addr_doc.gstin if addr_doc else doc.tax_id) or \"\" }}</strong></div>\n                        <div>Name : <strong>{{ (customer_doc.customer_name if customer_doc else doc.customer_name) or \"\" }}</strong></div>\n                        <div>Address : {{\n                            addr_doc.address_line1 + (\", \" + addr_doc.address_line2 if addr_doc.address_line2 else \"\") + \"<br>\" +\n                            addr_doc.city + \" (\" + addr_doc.state + \" )\" if addr_doc\n                            else \"\"\n                        }}</div>\n                        <div>State : {{ addr_doc.state if addr_doc else \"\" }} &nbsp;&nbsp;&nbsp; State Code : {{ addr_doc.gst_state_number if addr_doc else \"\" }}</div>\n                        <div>Mobile No. : {{ addr_doc.phone if addr_doc else \"\" }} &nbsp;&nbsp; Phone : {{ addr_doc.phone if addr_doc else \"\" }}</div>\n                    </td>\n                </tr>\n            </table>\n\n            <div class=\"section-title\">4.Item Details</div>\n            <table class=\"items-table\">\n                <thead>\n                    <tr>\n                        <th rowspan=\"2\" style=\"width: 4%;\">Sl<br>No</th>\n                        <th rowspan=\"2\" style=\"width: 35%;\">Description of Goods</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Hsn Code<br>(GST)</th>\n                        <th rowspan=\"2\" style=\"width: 5%;\">Qty</th>\n                        <th rowspan=\"2\" style=\"width: 5%;\">Unit</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Unit<br>Price</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Cash<br>Discount</th>\n                        <th rowspan=\"2\" style=\"width: 8%;\">Taxable<br>Value</th>\n                        <th colspan=\"2\" class=\"main-header\">CGST</th>\n                        <th colspan=\"2\" class=\"main-header\">SGST</th>\n                        <th colspan=\"2\" class=\"main-header\">IGST</th>\n                        <th rowspan=\"2\" style=\"width: 10%;\">Total</th>\n                    </tr>\n                    <tr>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    {% for row in doc.items %}\n                    <tr>\n                        <td>{{ row.idx or '' }}</td>\n                        <td class=\"desc-col\">{{ row.item_name or '' }}</td>\n                        <td>{{ row.gst_hsn_code or '' }}</td>\n                        <td>{{ row.qty or '' }}</td>\n                        <td>{{ row.uom or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.rate) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.discount_amount) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.qty * row.rate) or '' }}</td>\n                        <td>{{ row.get_formatted('cgst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.cgst_amount) or '' }}</td>\n                        <td>{{ row.get_formatted('sgst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.sgst_amount) or '' }}</td>\n                        <td>{{ row.get_formatted('igst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.igst_amount) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format((row.qty * row.rate) + row.cgst_amount + row.sgst_amount) or '' }}</td>\n                    </tr>\n                    {% endfor %}\n\n                    <tr class=\"total-row\">\n                        <td colspan=\"3\"><span style=\"float: left;\">E&OE</span> &nbsp;&nbsp;<span>Total :</span></td>\n                        <td>{{ doc.items | sum(attribute='qty') }}</td>\n                        <td></td>\n                        <td>{{ '{:,.2f}'.format(doc.items | sum(attribute='rate')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='discount_amount')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.total) or '' }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='cgst_amount')) }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='sgst_amount')) }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='igst_amount')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.grand_total) or '' }}</td>\n                    </tr>\n                </tbody>\n            </table>\n\n            <div class=\"section-title\">5.E Way Bill Details</div>\n            <table class=\"eway-table\">\n                <tr>\n                    <td style=\"width: 9%; font-weight: 600;\">E Way Bill No</td>\n                    <td style=\"width: 11%;\">{{ doc.ewaybill or '' }}</td>\n                    <td style=\"width: 10%; font-weight: 600;\">Vehicle Number</td>\n                    <td style=\"width: 12%;\">{{ doc.vehicle_no or '' }}</td>\n                    <td style=\"width: 14%; font-weight: 600; text-align: right;\">Discount</td>\n                    <td style=\"width: 12%; text-align: right;\">{{ '{:,.2f}'.format(doc.discount_amount) or '' }}</td>\n                </tr>\n                <tr>\n                    <td class=\"bold\">Eway Bill Date</td>\n                    <td>{{ doc.due_date }}</td>\n                    <td class=\"bold\">Valid Till Date</td>\n                    <td></td>\n                    <td class=\"bold\" style=\"text-align: right;\">Round To</td>\n                    <td style=\"text-align: right;\">{{ '{:,.2f}'.format(doc.rounded_total) or '' }}</td>\n                </tr>\n                <tr>\n                    <td colspan=\"4\"></td>\n                    <td class=\"bold\" style=\"text-align: right;\">Total</td>\n                    <td class=\"bold\" style=\"text-align: right;\">{{ '{:,.2f}'.format(doc.grand_total) or '' }}</td>\n                </tr>\n            </table>\n\n            <table class=\"bottom-table\">\n                <tr>\n                    <td class=\"qr-side-cell\">\n                        <img src=\"/files/federal_bank.png\" alt=\"Federal Bank UPI\">\n                        <div class=\"qr-caption\">Scan to Pay</div>\n                        <div class=\"qr-subcaption\">Federal Bank</div>\n                    </td>\n                    <td style=\"width: 56%; vertical-align: top;\">\n                        <div>Invoice Value (In Words)</div>\n                        <div class=\"bold\">\n                            {% set in_words = frappe.utils.money_in_words(doc.rounded_total or doc.grand_total, doc.currency) %}\n                            {{ in_words }}\n                        </div>\n                        <br>\n                        <div style=\"border-top: 1px solid #333 !important; padding-top: 4px;\">\n                            {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_default\": 1}, [\"account_name\", \"bank\", \"branch_code\", \"bank_account_no\"], as_dict=True) %}\n                            Bank Details : Bank Name : {{ bank.bank if bank else \"\" }}\n                        </div>\n                        <div><span style=\"margin-left: 66px;\">Branch :</span> {{ bank.branch_code if bank else \"\" }}</div>\n                        <div><span style=\"margin-left: 66px;\">A/C No :</span> {{ bank.bank_account_no if bank else \"\" }}</div>\n                        <div><span style=\"margin-left: 66px;\">IFSC :</span> FDRL0001511</div>\n                        <br>\n                        <div class=\"text-center bold\" style=\"margin-top: 8px;\">{{ doc.company or \"CHUNDAKADAN AGENCIES\" }}</div>\n                        <div class=\"text-center\" style=\"margin-top: 28px; padding-top: 4px; border-top: 1px solid #333 !important; display: inline-block; margin-left: 30%;\">Authorised Signatory</div>\n                    </td>\n                    <td class=\"qr-side-cell\">\n                        <img src=\"/files/feedback.png\" alt=\"Customer Feedback QR\">\n                        <div class=\"qr-caption\">Share Feedback</div>\n                        <div class=\"qr-subcaption\">Scan to give feedback</div>\n                    </td>\n                </tr>\n            </table>\n        </div>\n    </div>\n\n    <div id=\"footer-html\" class=\"visible-pdf\" style=\"position: fixed; bottom: 0; width: 100%; text-align: center; font-family: Arial, sans-serif; font-size: 10px;\">\n        {% if not is_no_need_letterhead and footer %}\n            <div class=\"letter-head-footer\">\n                {{ footer }}\n            </div>\n        {% endif %}\n    </div>\n</body>\n</html>\n",
