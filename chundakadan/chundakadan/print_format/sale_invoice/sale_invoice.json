{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2025-08-07 15:05:29.280140",
 "css": "",
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "Sales Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Invoice Template</title>\n    \n    <!-- Load Inter Variable font from Google Fonts -->\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap\" rel=\"stylesheet\">\n    \n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n            font-size: 11px;\n            line-height: 1.3;\n            background-color: #f5f5f5;\n            padding: 10px;\n            font-feature-settings: 'cv11', 'ss01';\n            font-variation-settings: 'slnt' 0;\n            -webkit-print-color-adjust: exact !important;\n            color-adjust: exact !important;\n            print-color-adjust: exact !important;\n        }\n\n        .invoice-container {\n            max-width: 210mm;\n            margin: 0 auto;\n            background: white;\n            border: 1px solid #333 !important;\n            color: #000;\n            position: relative;\n        }\n\n        /* Company Header - Full Width */\n        .company-header {\n            text-align: center;\n            padding: 8px;\n            width: 100%;\n            border-bottom: 1px solid #333 !important;\n        }\n\n        .company-gstin {\n            font-weight: 700;\n            font-size: 14px;\n            margin-bottom: 3px;\n            letter-spacing: 1px;\n        }\n\n        .company-name {\n            font-weight: 700;\n            font-size: 16px;\n            text-transform: uppercase;\n        }\n\n        /* Top Section with QR Code */\n        .top-section-wrapper {\n            display: flex;\n            position: relative;\n        }\n\n        .left-content {\n            flex: 1;\n            border-right: 1px solid #333 !important;\n        }\n\n        .qr-section {\n            width: 150px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 3px 10px;\n        }\n\n        .qr-code-container {\n            width: 130px;\n            height: 130px;\n            border: 1px solid #333 !important;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background-color: #fff;\n        }\n\n        .qr-code-container img {\n            width: 126px;\n            height: 126px;\n            object-fit: contain;\n        }\n\n        .qr-placeholder {\n            width: 126px;\n            height: 126px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 10px;\n            text-align: center;\n            color: #333;\n            background: repeating-linear-gradient(\n                45deg,\n                #666,\n                #666 1px,\n                #fff 1px,\n                #fff 3px\n            );\n        }\n\n        /* QR Code details section */\n        .qr-details {\n            width: 100%;\n            padding: 5px;\n            font-size: 9px;\n            text-align: center;\n        }\n\n        .qr-details p {\n            margin: 2px 0;\n            word-wrap: break-word;\n            word-break: break-all;\n            white-space: normal;\n        }\n\n        .field-property {\n            margin: 1px 0;\n        }\n\n        /* e-Invoice Section */\n        .einvoice-section {\n            width: 100%;\n            border-bottom: 1px solid #333 !important;\n        }\n\n        /* Transaction Section */\n        .transaction-section {\n            width: 100%;\n        }\n\n        .section-title {\n            font-weight: 600;\n            font-size: 11px;\n            margin: 0;\n            padding: 4px 8px;\n            width: 100%;\n        }\n\n        .einvoice-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 10px;\n            border-top: 1px solid #333 !important;\n        }\n\n        .einvoice-table td {\n            border-top: 1px solid #333 !important;\n            border-right: 1px solid #333 !important;\n            padding: 3px 6px;\n            vertical-align: top;\n            font-size: 11px;\n        }\n\n        .einvoice-table td:first-child {\n            width: 80px;\n            font-weight: 600;\n        }\n\n        .transaction-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 10px;\n        }\n\n        .transaction-table td {\n            border: 1px solid #333 !important;\n            padding: 3px 6px;\n            vertical-align: top;\n            font-size: 11px;\n        }\n\n        .transaction-table td:nth-child(1),\n        .transaction-table td:nth-child(3) {\n            width: 21%;\n            font-weight: 600;\n        }\n\n        .transaction-table td:nth-child(2),\n        .transaction-table td:nth-child(4) {\n            width: 30%;\n        }\n\n        /* Rest of content - Full Width */\n        .full-width-content {\n            width: 100%;\n        }\n\n        .party-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 10px;\n            border-top: 1px solid #333 !important;\n        }\n\n        .party-table td {\n            border: 1px solid #333 !important;\n            padding: 6px;\n            vertical-align: top;\n            width: 50%;\n        }\n\n        /* Items table */\n        .items-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 9px;\n        }\n\n        .items-table th, \n        .items-table td {\n            border: 1px solid #333 !important;\n            padding: 2px 3px;\n            text-align: center;\n            vertical-align: middle;\n        }\n\n        .items-table th {\n            font-weight: 600;\n            background-color: #f8f9fa !important;\n        }\n\n        .items-table .desc-col {\n            text-align: left;\n            font-size: 8px;\n        }\n\n        .items-table .num-col {\n            text-align: right;\n        }\n\n        /* Header styling for main columns */\n        .main-header {\n            background-color: #e9ecef !important;\n            font-weight: 700;\n        }\n\n        /* Sub-header styling */\n        .sub-header {\n            background-color: #f1f3f4 !important;\n            font-size: 8px;\n        }\n\n        .total-row {\n            font-weight: 600;\n        }\n\n        .eway-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 10px;\n        }\n\n        .eway-table td {\n            border: 1px solid #333 !important;\n            padding: 3px 6px;\n            vertical-align: top;\n        }\n\n        .bottom-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 10px;\n        }\n        .letter-head-container, \n        .letter-head-footer {\n            margin: 0;\n            padding: 0;\n            height: auto;\n        }\n\n        .bottom-table td {\n            border-left: 1px solid #333 !important;\n            padding: 8px;\n            vertical-align: top;\n        }\n\n        .bold { \n            font-weight: 600;\n        }\n        .text-right { text-align: right; }\n        .text-center { text-align: center; }\n\n        /* Enhanced Print Styles */\n        @media print {\n            body {\n                background: white !important;\n                padding: 0 !important;\n                margin: 0 !important;\n                -webkit-print-color-adjust: exact !important;\n                color-adjust: exact !important;\n                print-color-adjust: exact !important;\n            }\n            \n            .invoice-container {\n                border: 1px solid #333 !important;\n                box-shadow: none !important;\n                margin: 0 !important;\n                max-width: none !important;\n                width: 100% !important;\n            }\n            \n            /* Force all borders to print */\n            table, th, td {\n                border-color: #333 !important;\n                border-style: solid !important;\n                border-width: 0px !important;\n            }\n            \n            .company-header {\n                border-bottom: 1px solid #333 !important;\n            }\n            \n            .left-content {\n                border-right: 1px solid #333 !important;\n            }\n            \n            .einvoice-section {\n                border-bottom: 1px solid #333 !important;\n            }\n            \n            .qr-code-container {\n                border: 1px solid #333 !important;\n            }\n            \n            /* Ensure background colors print */\n            .items-table th {\n                background-color: #f8f9fa !important;\n                -webkit-print-color-adjust: exact !important;\n            }\n            \n            .main-header {\n                background-color: #e9ecef !important;\n                -webkit-print-color-adjust: exact !important;\n            }\n            \n            .sub-header {\n                background-color: #f1f3f4 !important;\n                -webkit-print-color-adjust: exact !important;\n            }\n        }\n\n        /* Additional browser-specific print fixes */\n        @page {\n            margin: 0.5in;\n            size: A4;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"invoice-container\">\n        <!-- Header -->\n        <div id=\"header-html\" class=\"letter-head-container\">\n            {% if letter_head %}\n                <div class=\"letter-head\">{{ letter_head }}</div>\n            {% endif %}\n        </div>\n        <!-- Company Header - Full Width -->\n        <div class=\"company-header\">\n            <div class=\"company-gstin\">32AAGFC3363E1ZX</div>\n            <div class=\"company-name\">CHUNDAKADAN AGENCIES</div>\n        </div>\n\n        <!-- Top Section containing e-Invoice, Transaction Details and QR Code -->\n        <div class=\"top-section-wrapper\">\n            <!-- Left side content -->\n            <div class=\"left-content\">\n                <!-- 1. e-Invoice Details -->\n                <div class=\"einvoice-section\">\n                    <div class=\"section-title\">1.e-Invoice Details</div>\n                    <table class=\"einvoice-table\">\n                        <tr>\n                            <td>IRN</td>\n                            <td><b>{{ doc.irn }}</b></td>\n                        </tr>\n                        <tr>\n                            <td>Ack No.</td>\n                            <td>\n                                {% if doc.irn %}\n                                    {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                                    {% if e_invoice_log %}\n                                        {% set invoice_data = json.loads(e_invoice_log.invoice_data) %}\n                                        {% set date_format = frappe.db.get_single_value(\"System Settings\",'date_format').replace(\"mm\",\"MM\") %}\n                                        <b>{{ invoice_data.get(\"AckNo\") if invoice_data.get(\"AckNo\") else '152522574952739' }}</b> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n                                        <span>Ack Date : <b>{{ frappe.utils.format_datetime(invoice_data.get(\"AckDt\"),date_format) if invoice_data.get(\"AckDt\") else doc.posting_date + ' ' + doc.posting_time }}</b></span>\n                                    {% else %}\n                                        <b>152522574952739</b> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n                                        <span>Ack Date : <b>{{ doc.posting_date }} {{ doc.posting_time }}</b></span>\n                                    {% endif %}\n                                {% else %}\n                                    <b>152522574952739</b> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n                                    <span>Ack Date : <b>{{ doc.posting_date }} {{ doc.posting_time }}</b></span>\n                                {% endif %}\n                            </td>\n                        </tr>\n                    </table>\n                </div>\n\n                <!-- 2. Transaction Details -->\n                <div class=\"transaction-section\">\n                    <div class=\"section-title\">2.Transaction Details</div>\n                    <table class=\"transaction-table\">\n                        <tr>\n                            <td>Category</td>\n                            <td><b>B2B</b></td>\n                            <td>Document No</td>\n                            <td><b>{{ doc.name }}</b></td>\n                        </tr>\n                        <tr>\n                            <td>Document Type</td>\n                            <td><b>{{ doc.select_print_heading if doc.select_print_heading else 'Tax Invoice' }}</b></td>\n                            <td>Document Date</td>\n                            <td><b>{{ doc.posting_date }}</b></td>\n                        </tr>\n                    </table>\n                </div>\n            </div>\n\n            <!-- QR Code Section on the right -->\n            <div class=\"qr-section\">\n                <div class=\"qr-code-container\">\n                    {% if doc.irn %}\n                        {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                        {% if e_invoice_log and e_invoice_log.signed_qr_code %}\n                            {{ web_block('e-Invoice QR', values={'e_invoice_qr_text': e_invoice_log.signed_qr_code }) }}\n              \n                        {% endif %}\n                   \n                    {% endif %}\n                </div>\n                \n                <!-- QR Code details below the QR code -->\n                {% if doc.irn %}\n                    {% set e_invoice_log = frappe.db.get_value(\"e-Invoice Log\", doc.irn, (\"invoice_data\", \"signed_qr_code\"), as_dict=True ) %}\n                    {% if e_invoice_log %}\n                        {% set invoice_data = json.loads(e_invoice_log.invoice_data) %}\n                        {% set date_format = frappe.db.get_single_value(\"System Settings\",'date_format').replace(\"mm\",\"MM\") %}\n                        <div class=\"qr-details\">\n                            <p class=\"field-property\">\n                                <b>IRN :</b><br>\n                                <span style=\"word-wrap: break-word;word-break: break-all;white-space: normal;\">{{ doc.irn }}</span>\n                            </p>\n                            <p class=\"field-property\">\n                                <b>Ack No.</b><br>\n                                <span>{{ invoice_data.get(\"AckNo\") if invoice_data.get(\"AckNo\") else '' }}</span>\n                            </p>\n                            <p class=\"field-property\">\n                                <b>Ack Dt.</b><br>\n                                <span>{{ frappe.utils.format_datetime(invoice_data.get(\"AckDt\"),date_format) if invoice_data.get(\"AckDt\") else '' }}</span>\n                            </p>\n                        </div>\n                    {% endif %}\n                {% endif %}\n            </div>\n        </div>\n\n        <!-- Rest of the content - Full Width -->\n        <div class=\"full-width-content\">\n            <!-- Details of Receiver (Billed to) -->\n            <div class=\"section-title\">Details of Receiver (Billed to)</div>\n            <table class=\"party-table\">\n                <tr>\n                    <td style=\"font-size: 11px;\">\n                        <div class=\"bold\">Seller</div><br>\n                        {% set company_addr = frappe.get_doc(\"Address\", doc.company_address) %}\n                        <div><span class=\"bold\">GSTIN :</span> <strong>{{ company_addr.gstin }}</strong></div>\n                        <div class=\"bold\">{{ company_addr.address_title }}</div>\n                        <div>{{ company_addr.address_line1 }}<br>{% if company_addr.address_line2 %},{{ company_addr.city }}</div>\n                        <div><span>PIN :</span> {{ company_addr.pincode }}</div>\n                        <div><span>E-Mail :</span> {{ company_addr.email_id }}</div>\n                        <div><span>State :</span> {{ company_addr.gst_state }}</div>\n                        <div><span>State Code :</span> {{ company_addr.gst_state_number }}</div>\n                        <div><span>Mobile :</span> {{ company_addr.phone }}</div>\n                        <div><span>Phone :</span> {{ company_addr.phone }}</div>\n                        {% endif %}\n                    </td>\n                    <td style=\"font-size: 11px;\">\n                        <div class=\"bold\">Purchaser</div><br>\n                        {%- set customer_doc = frappe.get_doc(\"Customer\", doc.customer) if doc.customer else None -%}\n                        {%- set addr_doc = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None -%}\n                        \n                        <div>GST No : <strong>{{ (addr_doc.gstin if addr_doc else doc.tax_id) or \"\" }}</strong></div>\n                        <div>Name : <strong>{{ (customer_doc.customer_name if customer_doc else doc.customer_name) or \"\" }}</strong></div>\n                        <div>Address : {{ \n                            addr_doc.address_line1 + (\", \" + addr_doc.address_line2 if addr_doc.address_line2 else \"\") + \"<br>\" + \n                            addr_doc.city + \" (\" + addr_doc.state + \" )\" if addr_doc \n                            else \"\" \n                        }}</div>\n                        <div>State : {{ addr_doc.state if addr_doc else \"\" }} &nbsp;&nbsp;&nbsp; State Code : {{ addr_doc.gst_state_number if addr_doc else \"\" }}</div>\n                        <div>Mobile No. : {{ addr_doc.phone if addr_doc else \"\" }} &nbsp;&nbsp; Phone : {{ addr_doc.phone if addr_doc else \"\" }}</div>\n                    </td>\n                </tr>\n            </table>\n\n            <!-- 4. Item Details -->\n            <div class=\"section-title\">4.Item Details</div>\n            <table class=\"items-table\">\n                <thead>\n                    <tr>\n                        <th rowspan=\"2\" style=\"width: 4%;\">Sl<br>No</th>\n                        <th rowspan=\"2\" style=\"width: 35%;\">Description of Goods</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Hsn Code<br>(GST)</th>\n                        <th rowspan=\"2\" style=\"width: 5%;\">Qty</th>\n                        <th rowspan=\"2\" style=\"width: 5%;\">Unit</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Unit<br>Price</th>\n                        <th rowspan=\"2\" style=\"width: 7%;\">Cash<br>Discount</th>\n                        <th rowspan=\"2\" style=\"width: 8%;\">Taxable<br>Value</th>\n                        <th colspan=\"2\" class=\"main-header\">CGST</th>\n                        <th colspan=\"2\" class=\"main-header\">SGST</th>\n                        <th colspan=\"2\" class=\"main-header\">IGST</th>\n                        <th rowspan=\"2\" style=\"width: 10%;\">Total</th>\n                    </tr>\n                    <tr>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                        <th class=\"sub-header\" style=\"width: 3%;\">%</th>\n                        <th class=\"sub-header\" style=\"width: 6%;\">Amount</th>\n                    </tr>\n                </thead>\n                \n                <tbody>\n                    {% for row in doc.items %}\n                    <tr>\n                        <td>{{ row.idx or '' }}</td>\n                        <td class=\"desc-col\">{{ row.item_name or '' }}</td>\n                        <td>{{ row.gst_hsn_code or '' }}</td>\n                        <td>{{ row.qty or '' }}</td>\n                        <td>{{ row.uom or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.rate) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.discount_amount) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.qty * row.rate) or '' }}</td>\n                        <td>{{ row.get_formatted('cgst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.cgst_amount) or '' }}</td>\n                        <td>{{ row.get_formatted('sgst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.sgst_amount) or '' }}</td>\n                        <td>{{ row.get_formatted('igst_rate') or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(row.igst_amount) or '' }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format((row.qty * row.rate) + row.cgst_amount + row.sgst_amount) or '' }}</td>\n                    </tr>\n                    {% endfor %}\n                    \n                    <!-- Total row -->\n                    <tr class=\"total-row\">\n                        <td colspan=\"3\"><span style=\"float: left;\">E&OE</span> &nbsp;&nbsp;<span>Total :</span></td>\n                        <td>{{ doc.items | sum(attribute='qty') }}</td>\n                        <td></td>\n                        <td>{{ '{:,.2f}'.format(doc.items | sum(attribute='rate')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='discount_amount')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.total) or '' }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='cgst_amount')) }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='sgst_amount')) }}</td>\n                        <td></td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.items | sum(attribute='igst_amount')) }}</td>\n                        <td class=\"num-col\">{{ '{:,.2f}'.format(doc.grand_total) or '' }}</td>\n                    </tr>\n                </tbody>\n            </table>\n\n            <!-- 5. E Way Bill Details -->\n            <div class=\"section-title\">5.E Way Bill Details</div>\n            <table class=\"eway-table\">\n                <tr>\n                    <td style=\"width: 9%; font-weight: 600;\">E Way Bill No</td>\n                    <td style=\"width: 11%;\"></td>\n                    <td style=\"width: 10%; font-weight: 600;\">Vehicle Number</td>\n                    <td style=\"width: 12%;\"></td>\n                    <td style=\"width: 14%; font-weight: 600; text-align: right;\">Discount</td>\n                    <td style=\"width: 12%; text-align: right;\">{{ '{:,.2f}'.format(doc.discount_amount) or '' }}</td>\n                </tr>\n                <tr>\n                    <td class=\"bold\">Eway Bill Date</td>\n                    <td>{{ doc.due_date }}</td>\n                    <td class=\"bold\">Valid Till Date</td>\n                    <td></td>\n                    <td class=\"bold\" style=\"text-align: right;\">Round To</td>\n                    <td style=\"text-align: right;\">{{ '{:,.2f}'.format(doc.rounded_total) or '' }}</td>\n                </tr>\n                <tr>\n                    <td colspan=\"4\"></td>\n                    <td class=\"bold\" style=\"text-align: right;\">Total</td>\n                    <td class=\"bold\" style=\"text-align: right;\">{{ '{:,.2f}'.format(doc.grand_total) or '' }}</td>\n                </tr>\n            </table>\n\n            <!-- Invoice Value in Words and Bank Details -->\n            <table class=\"bottom-table\">\n                <tr>\n                    <td style=\"width: 48%;\">\n                        <div>Invoice Value (In Words)</div>\n                        <div class=\"bold\">\n                            {% set in_words = frappe.utils.money_in_words(doc.rounded_total, doc.currency) %}\n                            {{ in_words }}\n                        </div>\n                        <br>\n                        <div style=\"border-top: 1px solid #333 !important;\">\n                            {% set bank = frappe.db.get_value(\"Bank Account\", {\"is_default\": 1}, [\"account_name\", \"bank\", \"branch_code\", \"bank_account_no\"], as_dict=True) %}\n                            Bank Details : Bank Name : {{ bank.bank if bank.bank else \"\" }}\n                        </div>\n                        <div><span style=\"margin-left: 66px;\">Branch :</span> {{ bank.branch_code if bank.branch_code else \"\" }}</div>\n                        <div><span style=\"margin-left: 66px;\">A/C No :</span> {{ bank.bank_account_no if bank.bank_account_no else \"\" }}</div>\n                        <div><span style=\"margin-left: 66px;\">IFSC :</span> FDRL0001511</div>\n                    </td>\n                    <td style=\"width: 30%;\" class=\"text-center\">\n                        <div style=\"height: 80px; display: flex; flex-direction: column; justify-content: space-between;\">\n                            <div class=\"bold\">CHUNDAKADAN AGENCIES</div>\n                            <br>\n                            <div>Authorised Signatory</div>\n                        </div>\n                    </td>\n                </tr>\n            </table>\n        </div>\n    </div>\n     <!-- Footer -->\n        <div id=\"footer-html\" class=\"visible-pdf\" style=\"position: fixed; bottom: 0; width: 100%; text-align: center; font-family: Arial, sans-serif; font-size: 10px;\">\n    {% if not is_no_need_letterhead and footer %}\n        <div class=\"letter-head-footer\">\n            {{ footer }}\n        </div>\n    {% endif %}\n</div>\n</body>\n</html>\n",
