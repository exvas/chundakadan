    "doctype": "Print Format",
    "font_size": 0,
    "html": "<style>\n.pss-wrap{font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;font-size:12px;color:#333;padding:30px;max-width:900px;margin:auto;}\n.pss-right{text-align:right;}\n.pss-center{text-align:center;}\n.pss-hr{border:0;border-top:1px solid #000;margin:10px 0 20px;}\n.pss-info{width:100%;border-collapse:collapse;margin-bottom:30px;}\n.pss-info td{padding:8px 4px;vertical-align:baseline;}\n.pss-lbl{font-weight:bold;width:18%;color:#000;}\n.pss-val{width:32%;}\n.pss-tbl{width:100%;border-collapse:collapse;margin-bottom:20px;}\n.pss-tbl th{background:#f8f9fa;border:1px solid #666;padding:10px;text-align:left;}\n.pss-tbl td{border:1px solid #ccc;padding:8px 10px;}\n.earn{color:#2e7d32;font-weight:bold;}\n.ded{color:#c62828;font-weight:bold;}\n.pss-sum-wrap{display:flex;justify-content:flex-end;}\n.pss-sum{width:50%;border-collapse:collapse;}\n.pss-sum td{padding:10px 5px;border-bottom:1px solid #eee;white-space:nowrap;}\n.pss-sum-lbl{font-weight:bold;width:40%;}\n.pss-sum-val{text-align:right;font-weight:bold;}\n.pss-words{margin-top:15px;font-style:italic;font-size:11px;text-align:right;color:#555;}\n.page-break{page-break-after:always;break-after:page;}\n\n/* Signature Styles */\n.pss-sig-container {\n    margin-top: 40px;\n    text-align: right;\n    padding-right: 20px;\n}\n.pss-sig-img {\n    max-height: 120px;\n    width: auto;\n}\n</style>\n\n{% for row in doc.salary_slips %}\n{% set s = frappe.get_doc(\"Salary Slip\", row.salary_slip) %}\n<div class=\"pss-wrap\">\n  <div class=\"pss-right pss-header\" style=\"margin-bottom:10px;\">\n    <h2 style=\"margin:0;font-size:22px;letter-spacing:1px;\">SALARY SLIP</h2>\n    <div style=\"color:#666;\">{{ s.name }}</div>\n  </div>\n  <div class=\"pss-hr\"></div>\n  <h3 class=\"pss-center\" style=\"text-transform:uppercase;margin-bottom:25px;\">{{ s.status }}</h3>\n  <table class=\"pss-info\">\n    <tr>\n      <td class=\"pss-lbl\">Employee</td><td class=\"pss-val\">{{ s.employee }}</td>\n      <td class=\"pss-lbl\">Posting Date</td><td class=\"pss-val\">{{ frappe.utils.formatdate(s.posting_date) }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Employee Name</td><td class=\"pss-val\">{{ s.employee_name }}</td>\n      <td class=\"pss-lbl\">Company</td><td class=\"pss-val\">{{ s.company }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Department</td><td class=\"pss-val\">{{ s.department }}</td>\n      <td class=\"pss-lbl\">Designation</td><td class=\"pss-val\">{{ s.designation }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Payroll Frequency</td><td class=\"pss-val\">{{ s.payroll_frequency }}</td>\n      <td class=\"pss-lbl\">Branch</td><td class=\"pss-val\">{{ s.branch }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Start Date</td><td class=\"pss-val\">{{ frappe.utils.formatdate(s.start_date) }}</td>\n      <td class=\"pss-lbl\">End Date</td><td class=\"pss-val\">{{ frappe.utils.formatdate(s.end_date) }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Working Days</td><td class=\"pss-val\">{{ s.total_working_days }}</td>\n      <td class=\"pss-lbl\">Payment Days</td><td class=\"pss-val\">{{ s.payment_days }}</td>\n    </tr>\n    <tr>\n      <td class=\"pss-lbl\">Leave Without Pay</td><td class=\"pss-val\">{{ s.leave_without_pay or 0 }}</td>\n      <td class=\"pss-lbl\">Absent Days</td><td class=\"pss-val\">{{ s.absent_days or 0 }}</td>\n    </tr>\n  </table>\n  <table class=\"pss-tbl\">\n    <thead>\n      <tr>\n        <th style=\"width:8%;\">Sr</th>\n        <th>Component</th>\n        <th style=\"width:20%;\">Type</th>\n        <th style=\"width:22%;text-align:right;\">Amount</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% set cnt = [] %}\n      {% for e in s.earnings %}\n        {% if cnt.append(1) %}{% endif %}\n        <tr>\n          <td>{{ cnt|length }}</td>\n          <td>{{ e.salary_component }}</td>\n          <td class=\"earn\">Earning</td>\n          <td class=\"pss-right\">{{ frappe.utils.fmt_money(e.amount, currency=s.currency) }}</td>\n        </tr>\n      {% endfor %}\n      {% for d in s.deductions %}\n        {% if cnt.append(1) %}{% endif %}\n        <tr>\n          <td>{{ cnt|length }}</td>\n          <td>{{ d.salary_component }}</td>\n          <td class=\"ded\">Deduction</td>\n          <td class=\"pss-right\">{{ frappe.utils.fmt_money(d.amount, currency=s.currency) }}</td>\n        </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n  <div class=\"pss-sum-wrap\">\n    <table class=\"pss-sum\">\n      <tr>\n        <td class=\"pss-sum-lbl\">Gross Pay</td>\n        <td class=\"pss-sum-val\">{{ frappe.utils.fmt_money(s.gross_pay, currency=s.currency) }}</td>\n      </tr>\n      <tr>\n        <td class=\"pss-sum-lbl\">Total Deduction</td>\n        <td class=\"pss-sum-val\">{{ frappe.utils.fmt_money(s.total_deduction, currency=s.currency) }}</td>\n      </tr>\n      <tr style=\"border-top:2px solid #000;\">\n        <td class=\"pss-sum-lbl\" style=\"font-size:14px;\">Net Pay</td>\n        <td class=\"pss-sum-val\" style=\"font-size:14px;\">{{ frappe.utils.fmt_money(s.net_pay, currency=s.currency) }}</td>\n      </tr>\n      <tr>\n        <td class=\"pss-sum-lbl\">Rounded Total</td>\n        <td class=\"pss-sum-val\">{{ frappe.utils.fmt_money(s.rounded_total or s.net_pay, currency=s.currency) }}</td>\n      </tr>\n    </table>\n  </div>\n  <div class=\"pss-words\"><strong>Amount in words:</strong> {{ s.total_in_words }}</div>\n</div>\n{% if not loop.last %}<div class=\"page-break\"></div>{% endif %}\n{% endfor %}\n\n<!-- Last Page Signature Section -->\n<div class=\"pss-sig-container\">\n    <img src=\"/files/20260514_110017.jpg-removebg-preview.png\" class=\"pss-sig-img\" alt=\"Authorized Signature\">\n    <div style=\"font-weight: bold; margin-top: 5px; padding-right: 10px;\">Manager Hr & Admin</div>\n</div>",
